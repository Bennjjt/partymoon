# ─────────────────────────────────────────────────────────────────
# Database (Neon Postgres)
# ─────────────────────────────────────────────────────────────────
# Neon project → Connection Details → Connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────────────
# Payload CMS
# ─────────────────────────────────────────────────────────────────
# Random secret used to sign auth tokens. Generate with:
#   openssl rand -hex 32
PAYLOAD_SECRET="change-me-to-a-random-32-char-string"

# ─────────────────────────────────────────────────────────────────
# Stripe Connect (Standard)
# ─────────────────────────────────────────────────────────────────
# Server-side secret key — never expose to the browser
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key — safe to expose in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook signing secret (from the Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────────────────────────
# Loops (email provider — waitlist and transactional)
# ─────────────────────────────────────────────────────────────────
# Loops dashboard → Settings → API Keys
# Waitlist signups are written to Payload first, then synced to Loops.
# If this key is absent, Loops sync is skipped and Payload remains the
# sole record — the user still sees the success confirmation.
LOOPS_API_KEY="loops_..."

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
# Public URL used for absolute links (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
