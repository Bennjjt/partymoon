# ─────────────────────────────────────────────────────────────────
# Database (Neon Postgres) — waitlist entries and bookings
# ─────────────────────────────────────────────────────────────────
# Neon project → Connection Details → Connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────────────
# Sanity CMS
# ─────────────────────────────────────────────────────────────────
# Project ID and dataset (safe to expose — used in GROQ queries on the client)
NEXT_PUBLIC_SANITY_PROJECT_ID="a6wgzngo"
NEXT_PUBLIC_SANITY_DATASET="production"

# Write token for the one-time Payload → Sanity migration script only.
# Never commit, never expose to the browser.
SANITY_API_WRITE_TOKEN=""

# Viewer token for reading drafts in preview/draft mode. Create in
# manage.sanity.io → API → Tokens, with "Viewer" permissions.
SANITY_API_READ_TOKEN=""

# Signing secret from the Sanity webhook (manage.sanity.io → API → Webhooks)
# that POSTs to /api/webhooks/sanity on publish/unpublish.
SANITY_WEBHOOK_SECRET=""

# Vercel project Settings → Git → Deploy Hooks, targeting the main branch.
# The webhook above calls this to trigger a production rebuild on publish.
VERCEL_DEPLOY_HOOK_URL=""

# ─────────────────────────────────────────────────────────────────
# Stripe Connect (Standard)
# ─────────────────────────────────────────────────────────────────
# Server-side secret key — never expose to the browser
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key — safe to expose in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook signing secret (from the Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────────────────────────
# Loops (email provider — waitlist and transactional)
# ─────────────────────────────────────────────────────────────────
# Loops dashboard → Settings → API Keys
# Waitlist signups are written to Postgres (Drizzle) first, then synced to Loops.
# If this key is absent, Loops sync is skipped and the DB remains the
# sole record — the user still sees the success confirmation.
LOOPS_API_KEY="loops_..."

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
# Public URL used for absolute links (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
